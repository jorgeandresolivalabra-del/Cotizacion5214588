  </footer>
</div>

<script>
  const copyBtn = document.getElementById('copyLinkBtn');
  const printBtn = document.getElementById('printBtn');
  const shareBtn = document.getElementById('shareBtn');
  const toast = document.getElementById('toastMessage');

  function showMessage(text, isError = false) {
    toast.style.backgroundColor = isError ? '#b13e3e' : '#1e6f5c';
    toast.textContent = text;
    toast.style.opacity = '1';
    setTimeout(() => { toast.style.opacity = '0'; }, 2800);
  }

  copyBtn.addEventListener('click', () => {
    const currentUrl = window.location.href;
    if (currentUrl.startsWith('file://')) {
      showMessage('⚠️ Vista local. Para compartir el link, súbela a un hosting (Netlify/GitHub Pages) o envía el archivo HTML.', true);
      navigator.clipboard.writeText(currentUrl).catch(() => showMessage('No se pudo copiar', true));
    } else {
      navigator.clipboard.writeText(currentUrl).then(() => showMessage('✅ Enlace copiado. ¡Puedes enviarlo por WhatsApp o email!', false))
        .catch(() => showMessage('Error al copiar', true));
    }
  });

  printBtn.addEventListener('click', () => { window.print(); });

  shareBtn.addEventListener('click', async () => {
    const shareData = {
      title: 'Cotización Dualtec N°01251 - Sistema de Pedidos de Almuerzo',
      text: 'Maca Lamas, tu cotización para el proyecto SaaS de pedidos de almuerzo (Next.js + Supabase + MercadoPago) ya está disponible.',
      url: window.location.href,
    };
    if (navigator.share && !window.location.href.startsWith('file://')) {
      try {
        await navigator.share(shareData);
        showMessage('Compartido correctamente');
      } catch (err) {
        if (err.name !== 'AbortError') showMessage('No se pudo compartir', true);
      }
    } else {
      if (window.location.href.startsWith('file://')) {
        showMessage('Para compartir, sube el archivo a un hosting (Vercel/Netlify) o envía el .html', true);
      } else {
        navigator.clipboard.writeText(window.location.href).then(() => showMessage('Enlace copiado al portapapeles, listo para compartir', false))
          .catch(() => showMessage('Error al copiar', true));
      }
    }
  });

  if (window.location.href.startsWith('file://')) {
    setTimeout(() => showMessage('📁 Estás viendo la cotización local. Para enviar un link público, súbela a un hosting (ej: Vercel, Netlify).', false), 600);
  }
</script>
